# ===================================================
# 위탁판매 자동화 시스템 — 환경변수 설정
# 이 파일을 복사하여 .env 로 저장 후 값을 채워주세요
# ===================================================

# ── 오너클랜 API ──────────────────────────────────
OWNERCLAN_API_KEY=your_ownerclan_api_key_here
OWNERCLAN_API_SECRET=your_ownerclan_api_secret_here
OWNERCLAN_BASE_URL=https://api.ownerclan.com

# ── 쿠팡 Open API ────────────────────────────────
COUPANG_ACCESS_KEY=your_coupang_access_key_here
COUPANG_SECRET_KEY=your_coupang_secret_key_here
COUPANG_VENDOR_ID=your_vendor_id_here
COUPANG_BASE_URL=https://api-gateway.coupang.com

# ── Claude (Anthropic) API ───────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Slack 알림 ────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── DB ───────────────────────────────────────────
# SQLite (기본, 로컬 개발용)
DATABASE_URL=sqlite+aiosqlite:///./sales_automation.db
# PostgreSQL (프로덕션) — 주석 해제하여 사용
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sales_automation

# ── 시스템 설정 ───────────────────────────────────
# Mock 모드: true 이면 실제 API 호출 없이 샘플 데이터 반환
MOCK_MODE=true

# 마진율 기준 (이 이하면 자동 필터링)
MARGIN_THRESHOLD_PERCENT=10.0

# 최저 판매일 수 (이 기간 동안 판매 0건 시 하차 후보)
POOR_SALES_DAYS=14

# 서버 포트
PORT=8000
APP_ENV=development
